package Array;
public class Largestnumber {
	public static void main(String[] args) {
		int arr[] = {10, 45, 78, 23, 99, 56};
        int largest = arr[0];
        for(int i = 1; i < arr.length; i++) {
            if(arr[i] > largest) {
                largest = arr[i];
            }
        }
        System.out.println("Largest number is: " + largest);
	}

}
